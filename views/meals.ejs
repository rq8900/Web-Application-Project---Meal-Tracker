

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <title>Meal Tracker</title>

    <style>
        body {
            font-family: Arial;
            
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 30px;
        }

        th, td {
            border: 1px solid #ccc;
            padding: 10px;
            text-align: center;
        }

        th {
            background: #333;
            color: white;
        }

        .delete-btn {
            background: red;
            color: white;
            border: none;
            padding: 5px 10px;
            cursor: pointer;
        }

        .add-section input {
            padding: 8px;
            margin: 5px;
        }

        .add-section button {
            padding: 8px 12px;
        }
    </style>

</head>
<body>
    <%- include ('partials/navbar.ejs') %>

<h1>🍱 My Meal Tracker</h1>

<a href="/meals/add" class="btn btn-success">
    ➕ Add New Meal
</a>
<!-- ================= ALL MEALS (NOW TOP) ================= -->
<h2>All Meals</h2>

<div class="table-responsive">

<table class="table table-striped table-hover table-bordered align-middle">

    <thead class="table-dark">
        <tr>
            <th>Meal</th>
            <th>Location</th>
            <th>Calories</th>
            <th>Rating</th>
            <th>Comment</th>
            <th>Action</th>
        </tr>
    </thead>

    <tbody>
        <% mealsList.forEach((meal, index) => { %>
        <tr>
            <td><%= meal.name %></td>
            <td><%= meal.location %></td>
            <td><%= meal.calories %> kcal</td>
            <td>
                <% for (let i = 1; i <= 5; i++) { %>
                    <% if (i <= meal.rating) { %>
                        ★
                    <% } else { %>
                        ☆
                    <% } %>
                <% } %>
            </td>
            <td><%= meal.comment %></td>

            <td>
            <a href="/meals/<%= index %>" class="btn btn-primary btn-sm">
                View
            </a>

            <a href="/meals/edit/<%= index %>" class="btn btn-warning btn-sm">
                Edit
            </a>

                <form action="/meals/delete/<%= index %>" 
                      method="POST" 
                      class="d-inline">

                    <input type="hidden" name="index" value="<%= index %>">

                    <button class="btn btn-danger btn-sm">
                        Delete
                    </button>

                </form>
            </td>
        </tr>
        <% }) %>
    </tbody>

</table>

</div>  
<!-- ================= ADD MEAL (NOW BELOW) ================= -->


</body>
</html>